# Copy this file to `.dev.vars` (git-ignored) for local `npm run dev:worker`.
# These are the SERVER-SIDE values the /api/summary Worker reads from `env` —
# they are NOT VITE_ vars and never reach the browser bundle.
#
# In production set these on the WORKER (not a build/CI variable, which the
# running Worker can't read): dashboard -> your Worker -> Settings ->
# Variables and Secrets. ANTHROPIC_API_KEY must be a "Secret"; the SUPABASE_*
# values can be plaintext "Variables".

# Anthropic API key (console.anthropic.com). Billed usage-based, separate from
# any Claude Max subscription. Set a monthly budget in the Console.
ANTHROPIC_API_KEY=sk-ant-...

# Only this signed-in email may use the summary endpoint (must match the
# EDITOR_EMAIL the frontend gates on). Defaults to p.lilford@gmail.com if unset.
EDITOR_EMAIL=p.lilford@gmail.com

# Supabase project the Worker reads context/resources from + verifies the
# login JWT against (anon/publishable key — reads are public under RLS). The
# Worker also accepts the VITE_ names as a fallback.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-publishable-anon-key
