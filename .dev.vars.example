# Copy this file to `.dev.vars` (git-ignored) for local `npm run pages:dev`.
# These are the SERVER-SIDE secrets the /api/summary Cloudflare Pages Function
# reads from `context.env` — they are NOT VITE_ vars and never reach the
# browser bundle.
#
# In production, set the same keys in the Cloudflare Pages dashboard:
#   Settings -> Environment variables (Production + Preview).

# Anthropic API key (console.anthropic.com). Billed usage-based, separate from
# any Claude Max subscription. Set a monthly budget in the Console.
ANTHROPIC_API_KEY=sk-ant-...

# Only this signed-in email may use the summary endpoint (must match the
# EDITOR_EMAIL the frontend gates on). Defaults to p.lilford@gmail.com if unset.
EDITOR_EMAIL=p.lilford@gmail.com

# Supabase project the function reads context/resources from (anon key — reads
# are public under RLS). The function also accepts the VITE_ names as a
# fallback, so if your Pages project already exposes those to Functions you can
# omit these two.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
