# Copy this file to .env and fill in real values.
# .env is git-ignored.
#
# ----- LOCAL DEVELOPMENT (default) -----
# After `supabase start`, copy the values it prints to the terminal.
# The URL is usually http://127.0.0.1:54321 and the anon / service_role
# keys are deterministic across local stacks.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=paste-anon-key-printed-by-supabase-start

# Used by tools/import_spreadsheet.py only. NEVER ship to the frontend.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=paste-service-role-key-printed-by-supabase-start

# ----- WHEN YOU EVENTUALLY DEPLOY -----
# Swap the four values above for the ones from the hosted Supabase dashboard
# (Project Settings -> API). No code changes needed.
